# PlaySight AI — environment variables
# Copy to .env and set values for your environment.

PORT=3000
DATABASE_URL=postgres://playsight:playsight@localhost:5432/playsight
REDIS_URL=redis://localhost:6379

# S3-compatible storage (MinIO in dev; leave empty for AWS S3)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=playsight
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_USE_SSL=false

# Optional: for web app when talking to API (e.g. http://localhost:3000)
# VITE_API_URL=http://localhost:3000
